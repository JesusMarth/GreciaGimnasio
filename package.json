{
  "name": "gymgrecia",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "description": "Gestion de socios y cuotas del gimnasio (gimnasio, karate, pilates)",
  "scripts": {
    "dev": "concurrently -n server,web -c green,cyan \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "typecheck": "tsc -p web/tsconfig.json --noEmit",
    "test:filtros": "tsx web/filtros.pruebas.ts",
    "test:ingresos": "tsx server/ingresos.pruebas.ts",
    "seed:mock": "tsx server/seed-mock.ts",
    "dist": "node scripts/dist.mjs",
    "preversion": "npm run typecheck && tsc -p tsconfig.json --noEmit && npm run test:filtros",
    "version": "git add CHANGELOG.md",
    "postversion": "git push --follow-tags"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "nodemailer": "^9.0.1",
    "pdfkit": "^0.19.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.6",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
